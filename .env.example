# Copy to .env and fill in. Only set what your chosen backend needs.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Qdrant (if backend: qdrant). Must match the key you launched the container with.
QDRANT_API_KEY=change-me

# Postgres (if backend: pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ragdb

# SEC EDGAR requires a descriptive User-Agent with contact info
SEC_USER_AGENT=Your Name your@email.com

# Optional: Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Tell the API which config to load
RAG_CONFIG=config.yaml
